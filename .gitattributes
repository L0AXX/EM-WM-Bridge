# Ensure shell scripts use LF line endings (critical for Linux CI)
*.sh         text eol=lf
gradlew      text eol=lf

# Java sources
*.java       text eol=lf
*.kts        text eol=lf
*.gradle     text eol=lf

# Config files
*.yml        text eol=lf
*.yaml       text eol=lf
*.properties text eol=lf
*.xml        text eol=lf
*.md         text eol=lf

# Binary files
*.jar        binary
*.png        binary
*.jpg        binary
*.gif        binary
*.docx       binary
*.pdf        binary
